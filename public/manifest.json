{
  "manifest_version": 3,
  "name": "Clear History",
  "version": "1.0.0",
  "description": "Clear browser history",
  "permissions": ["history", "storage"],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "img/Y.png"
    }
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "img/Y.png",
    "48": "img/Y.png",
    "128": "img/Y.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["img/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
